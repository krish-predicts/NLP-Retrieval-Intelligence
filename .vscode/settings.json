{
  "python.analysis.extraPaths": [
    "./project",
    "./project/src"
  ],
  "python.autoComplete.extraPaths": [
    "./project",
    "./project/src"
  ],
  "python.envFile": "${workspaceFolder}/project/.env",
  "python.terminal.activateEnvironment": true,
  "python-envs.defaultEnvManager": "ms-python.python:system",
  "files.exclude": {
    "**/__pycache__": true,
    "**/.pytest_cache": true
  }
}
